# Puerto HTTP en el que escucha la API.
APP_PORT=8080

# Motor de persistencia: "memory" (por defecto, sin dependencias) o "mongo".
DB_DRIVER=memory

# Configuración de MongoDB (solo se usa cuando DB_DRIVER=mongo).
MONGO_URI=mongodb://localhost:27017
MONGO_DB=productsdb
MONGO_COLLECTION=products

# Timeouts (formato de duración de Go: 5s, 500ms, 1m, etc.).
REQUEST_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s
